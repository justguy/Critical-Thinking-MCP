    {
      "id": "s1",
      "description": "A leader sends QUACK_PREPARE(term,state_hash,mood) to followers.",
      "dependencies": [],
      "resources": ["leader", "followers", "network", "term", "state_hash", "mood"]
    },
    {
      "id": "s2",
