      "id": "s3",
      "description": "A value commits after 2f+1 matching acknowledgments.",
      "dependencies": ["s2"],
      "resources": ["quorum", "acks", "state_hash"]
    },
    {
      "id": "s4",
      "description": "Heartbeats run every 50 ms, and elections start after 150 ms.",
      "dependencies": ["s1", "s2"],
      "resources": ["timers", "leader", "followers", "network"]
    },
    {
      "id": "s5",
      "description": "Under a partition, only the majority partition accepts writes and the minority goes read-only.",
      "dependencies": ["s3", "s4"],
      "resources": ["partitioned_network", "majority_partition", "minority_partition", "quorum"]
    },
    {
      "id": "s6",
      "description": "Emotional distress doubles timeout values but does not affect safety because votes remain monotonic and durable.",
      "dependencies": ["s4"],
      "resources": ["timers", "votes", "durable_state", "ducks"]
    },
    {
      "id": "s7",
      "description": "Correctness follows from quorum intersection: two majorities share at least one duck, so committed state cannot fork, and liveness returns once the partition heals.",
      "dependencies": ["s3", "s5", "s6"],
      "resources": ["quorum", "votes", "committed_state", "partitioned_network"]
    }
  ]
}
```
